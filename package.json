{
  "name": "drop-player",
  "version": "1.2.4",
  "description": "A comprehensive, universal, open-source React media player powering drop.mov.",
  "license": "MIT",
  "author": "kumo.productions™",
  "repository": "github:kumoproductions/drop-player",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/index.css"
  ],
  "keywords": [
    "react",
    "player",
    "media-player",
    "video-player",
    "audio-player",
    "hls",
    "pdf-viewer",
    "image-viewer",
    "component"
  ],
  "homepage": "https://github.com/kumoproductions/drop-player#readme",
  "bugs": {
    "url": "https://github.com/kumoproductions/drop-player/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --config demo/vite.config.ts",
    "build": "vite build",
    "build:demo": "vite build --config demo/vite.config.ts",
    "preview:demo": "vite preview --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:llms": "node scripts/generate-llms-txt.mjs",
    "prebuild:demo": "node scripts/generate-llms-txt.mjs",
    "prepublishOnly": "npm run build",
    "prepare": "node -e \"try{require('fs').statSync('.husky')}catch{process.exit(1)}\" && npx husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,css}": "biome check --write"
  },
  "peerDependencies": {
    "hls.js": "^1.4.0",
    "lucide-react": ">=0.300.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "pdfjs-dist": "^5.0.0",
    "waveform-data": "^4.5.0"
  },
  "peerDependenciesMeta": {
    "hls.js": {
      "optional": true
    },
    "pdfjs-dist": {
      "optional": true
    },
    "waveform-data": {
      "optional": true
    }
  },
  "overrides": {
    "@tailwindcss/vite": {
      "vite": "$vite"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@cumuloworks/configs": "^2.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "hls.js": "^1.6.15",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lucide-react": "^0.577.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0",
    "waveform-data": "^4.5.2"
  }
}
